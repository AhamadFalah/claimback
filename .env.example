# Xero app credentials — developer.xero.com -> My Apps -> New app (Web app)
# Redirect URI must be registered exactly as below.
XERO_CLIENT_ID=
XERO_CLIENT_SECRET=
XERO_REDIRECT_URI=http://localhost:8912/callback

# Guardrail: nothing is filed or posted to Xero while true
DRY_RUN=true

# Detection thresholds
NO_SCAN_DAYS=10
CLAIM_WINDOW_DAYS=28
